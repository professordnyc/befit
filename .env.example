# =========
# Core env
# =========
BEFIT_ENV=development  # set to "production" on Render

# Public frontend base URL (Netlify)
PUBLIC_APP_BASE_URL=https://your-netlify-site.netlify.app

# Public backend base URL (FastAPI on Render)
PUBLIC_API_BASE_URL=https://your-befit-backend.onrender.com

# ===========
# LLM / Goose
# ===========
# Primary key used by the app
OPENROUTER_API_KEY=your-openrouter-api-key
# Optional: only if some code still references OPENAI_API_KEY
OPENAI_API_KEY=your-openrouter-api-key
# ==========
# Database
# ==========
# Local dev Postgres; Render will override with its own DATABASE_URL
DATABASE_URL=postgresql://user:password@localhost:5432/befit_dev

# =========================
# Speech (ElevenLabs)
# =========================
ELEVENLABS_API_KEY=your-elevenlabs-api-key
ELEVENLABS_BASE_URL=https://api.elevenlabs.io

# Text-to-Speech (TTS)
ELEVENLABS_TTS_VOICE_ID=default-voice-id
ELEVENLABS_TTS_MODEL_ID=eleven_turbo_v2_5
ELEVENLABS_TTS_OUTPUT_FORMAT=mp3_44100_128

# Speech-to-Text (STT)
ELEVENLABS_STT_MODEL_ID=default-stt-model
ELEVENLABS_STT_LANGUAGE=en

# ── TTS fallback ───────────────────────────────────────────────────────────────
# When ELEVENLABS_API_KEY is absent or credits are exhausted, POST /tts returns
# 503 and the browser falls back to window.speechSynthesis (WebSpeech API)
# automatically — no extra server config needed.
# Set to "true" to skip ElevenLabs entirely and always use the WebSpeech fallback.
# FORCE_WEBSPEECH_TTS=false

# ── CORS ─────────────────────────────────────────────────────────────────────────────────────
# Comma-separated allowed origins (defaults to * if not set)
# ALLOWED_ORIGINS=https://yourapp.netlify.app,https://yourapp.onrender.com


# ===========
# Vision
# ===========
MEDIAPIPE_ENABLED=true

# ===========
# Legacy / optional
# ===========
CONVEX_URL=

# Optional: comma-separated allowed CORS origins
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:8000
