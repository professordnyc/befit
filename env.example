# Copy this file to .env and fill in your values.

# Required: Your OpenRouter (or OpenAI) API key
OPENAI_API_KEY=your-key-here

# Optional: API base URL (default is OpenRouter)
OPENAI_BASE_URL=https://openrouter.ai/api/v1

# Optional: Model to use (default: anthropic/claude-3-5-sonnet)
BEFIT_MODEL=anthropic/claude-3-5-sonnet

# Optional: Comma-separated allowed CORS origins (default: * for development)
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:8000
