# .env example

# LLM / Orchestration
OPENROUTER_API_KEY=your-openrouter-key

# Speech (ElevenLabs)
ELEVENLABS_API_KEY=your-elevenlabs-key
ELEVENLABS_TTS_VOICE_ID=default-voice-id

# Vision / Live frame (MediaPipe or similar)
MEDIAPIPE_ENABLED=true

# Storage / Database (optional; each may not be used)
CONVEX_URL=your-convex-url
DATABASE_URL=your-database-url-or-connection-string

# Deployment environment
BEFIT_ENV=development
PUBLIC_APP_BASE_URL=http://localhost:3000
